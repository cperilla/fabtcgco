---
import EventTicket from '../components/EventTicket.astro';
import Layout from '../layouts/Layout.astro';

import { loadEventsData } from '../utils/dataLoader';
import { formatMonthName } from '../utils/calendarUtils';

const eventsData = loadEventsData();
const year = new Date(eventsData[0].Date).getFullYear().toString();

// Transform and sort all events (no date filtering - done client-side)
const allEvents = eventsData
    .map(e => ({
        icon: e.Emoji,
        type: e.EventType,
        title: e.Event,
        time: e.Time,
        location: { spot: e.Location, city: e.Ciudad },
        date: e.Date,
        dateObj: new Date(e.Date),
        key: `${e.Date}-${e.Event}-${e.Time}`,
        tournamentUrl: e.TournamentURL,
        tournamentName: e.TournamentName,
    }))
    .sort((a, b) => a.dateObj.getTime() - b.dateObj.getTime());

// Group events by month for display
const eventsByMonth = allEvents.reduce((acc, event) => {
    const month = event.dateObj.getMonth() + 1;
    if (!acc[month]) acc[month] = [];
    acc[month].push(event);
    return acc;
}, {} as Record<number, typeof allEvents>);

const months = Object.keys(eventsByMonth).map(Number).sort((a, b) => a - b);

let globalIndex = 0;
---

<Layout>
<div class="calendar-page">
    <div class="calendar-header">
        <h1>Calendario</h1>
        <div class="stars">
            <span style="color: #91160d;">★</span>
            <span style="color: #765d2f;">★</span>
            <span style="color: #91160d;">★</span>
            <span style="color: #765d2f;">★</span>
            <span style="color: #91160d;">★</span>
        </div>
        <p class="subtitle">Próximos eventos de la comunidad</p>
    </div>
    <div class="events-container" id="events-container">
        {months.map((month) => {
            const events = eventsByMonth[month];
            const monthName = formatMonthName(month, year);
            return (
                <section data-month={month}>
                    <h2 class="calendar-month-header">{monthName} {year}</h2>
                    {events.map((event) => {
                        const idx = globalIndex++;
                        return <EventTicket event={event} index={idx} />;
                    })}
                </section>
            );
        })}
    </div>
</div>
</Layout>

<script>
  function updateCalendarStates() {
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    const tickets = document.querySelectorAll('.event-ticket');
    const ticketData: { element: HTMLElement; date: Date; key: string }[] = [];

    // Collect all ticket data
    tickets.forEach(ticket => {
      const dateStr = ticket.getAttribute('data-event-date');
      const key = ticket.getAttribute('data-event-key');
      if (dateStr && key) {
        ticketData.push({
          element: ticket as HTMLElement,
          date: new Date(dateStr + 'T00:00:00'),
          key
        });
      }
    });

    // Sort by date
    ticketData.sort((a, b) => a.date.getTime() - b.date.getTime());

    // Split into past and future
    const pastTickets = ticketData.filter(t => t.date < today);
    const futureTickets = ticketData.filter(t => t.date >= today);

    // Find the next event (first future event)
    const nextEventKey = futureTickets.length > 0 ? futureTickets[0].key : null;

    // Get the last 3 past events to show
    const recentPastKeys = new Set(pastTickets.slice(-3).map(t => t.key));

    // Apply classes and visibility
    ticketData.forEach(t => {
      const isPast = t.date < today;
      const isNext = t.key === nextEventKey;

      // Remove any existing state classes
      t.element.classList.remove('event-ticket--past', 'event-ticket--next', 'event-ticket--hidden');

      // Remove existing next-badge if any
      const existingBadge = t.element.querySelector('.next-badge');
      if (existingBadge) existingBadge.remove();

      if (isPast) {
        if (recentPastKeys.has(t.key)) {
          t.element.classList.add('event-ticket--past');
        } else {
          t.element.classList.add('event-ticket--hidden');
        }
      } else if (isNext) {
        t.element.classList.add('event-ticket--next');
        // Add next badge
        const badge = document.createElement('span');
        badge.className = 'next-badge';
        badge.textContent = 'Próximo';
        t.element.insertBefore(badge, t.element.firstChild);
      }
    });

    // Hide empty month sections
    document.querySelectorAll('[data-month]').forEach(section => {
      const visibleTickets = section.querySelectorAll('.event-ticket:not(.event-ticket--hidden)');
      if (visibleTickets.length === 0) {
        (section as HTMLElement).style.display = 'none';
      } else {
        (section as HTMLElement).style.display = '';
      }
    });
  }

  // Run on page load
  document.addEventListener('DOMContentLoaded', updateCalendarStates);
  // Also run immediately in case DOMContentLoaded already fired
  if (document.readyState !== 'loading') {
    updateCalendarStates();
  }
</script>
