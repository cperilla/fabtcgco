---
import Layout from '../layouts/Layout.astro';

const mechanics = [
  { name: "Dominante", description: "El Héroe defensor no puede defender este ataque con más de 1 carta de su mano (incluidas cartas de Reacción Defensa).", color: "green" },
  { name: "Go Again", description: "Go again permite que podamos realizar diversas acciones en un turno. Una carta con go again le da al jugador que la utiliza un punto de acción adicional.", color: "green" },
  { name: "Opt X", description: "Observe X cartas del tope de su baraja. Puede colocarlas ya sea en el tope o en el fondo de la baraja en cualquier orden.", color: "green" },
  { name: "Overpower", description: "El Héroe defensor no puede defender con más de una carta de acción.", color: "green" },
  { name: "Ward X", description: "Si el Héroe fuera a recibir daño, previene X de ese daño y se destruye esta carta.", color: "yellow" },
  { name: "Blood Debt", description: "Al inicio de su fase final, si esta carta se encuentra en su zona de removidos o desterrados, el Héroe decide si pagar 3 recursos o de lo contrario pierde 2 puntos de vida.", color: "yellow" },
  { name: "Boost", description: "Como costo adicional para jugar esta carta, puedes remover o desterrar la carta del tope de tu baraja. Si esa carta es de mecha Esta carta obtiene go again.", color: "yellow" },
  { name: "Clash", description: "Los Héroes enfrentados revelan la carta del tope de sus respectivas barajas. Si se revela la carta con el mayor valor, gana el enfrentamiento. No hay efecto si no hay un ganador. Si la carta no tiene valor de ataque se considera 0", color: "yellow" },
  { name: "Combo", description: "Una mecánica Ninjas que obtiene su poder en la secuenciación de distintos ataques.", color: "yellow" },
  { name: "Contract", description: "Contract le da una serie de instrucciones al jugador para que las complete y cumpla con el Contract. Pueden ser completados cualquier número de veces mientras estén activos en la cadena de combate.", color: "green" },
  { name: "Crush", description: "Una mecánica de Guardians enfocada en aprovechar el valor de sus ataques. Cuando un ataque con Crush causa 4 o más de daño al Héroe enemigo, el efecto de Crush se activa.", color: "green" },
  { name: "Intimidate", description: "El Héroe objetivo remueve o destierra de su mano una carta al azar. Se destierra boca abajo, solo su dueño puede verla", color: "green" },
  { name: "Phantasm", description: "Si esta carta es defendida por una carta, que no sea de Ilusionista, con poder de ataque 6 o más, destruye esta carta. El ataque no se resuelve.", color: "green" },
  { name: "Reload", description: "Si no tienes cartas en tu arsenal, puedes colocar una carta boca abajo de tu mano en el arsenal.", color: "green" },
  { name: "Reprise", description: "Se activa reprise cuando el héroe defensor ha defendido con una carta desde su mano", color: "yellow" },
  { name: "Spectra", description: "Esta carta puede ser atacada. Cuando esta carta se convierte en el objetivo de un ataque, se destrye. El ataque no se resuelve.", color: "yellow" },
  { name: "Stealth", description: "Stealth es una habilidad sin reglas que funciona específica para esta clase como una habilidad \"vacía\".", color: "yellow" },
  { name: "Transcend", description: "Pon esta carta en la mano de su dueño volteada.", color: "yellow" },
  { name: "Wager", description: "Cuando la cadena de este ataque se resuelve, si el ataque golpea, creas un [token], de lo contrario el Héroe objetivo crea un [token].", color: "green" },
  { name: "~X Element~ Fusion", description: "Como un costo adicional para jugar esta carta, puedes revelar una carta de ~X Element~ desde tu mano.", color: "yellow" },
  { name: "Charge", description: "Como un costo adicional para jugar esta carta, puedes cargar el Alma de tu Héroe. Coloque una carta de tu mano boca arriba bajo su carta de Héroe.", color: "orange" },
  { name: "Crank", description: "Cuando esta carta entra en la arena, puedes remover uno de sus \"Steam Counter\". Si lo haces, ganas 1 punto de Acción.", color: "orange" },
  { name: "Galvanize", description: "Galvanize - cuando esta carta defiende, puedes destruir un Item bajo tu control. Si lo haces, [...]", color: "orange" },
  { name: "Piercing X", description: "Si esta carta es defendida por un equipo, gana +X de poder.", color: "orange" },
  { name: "Scrap", description: "Como un costo adicional para jugar esta carta, puedes remover un Item o Equipo de tu cementerio.", color: "orange" },
  { name: "Amp", description: "La próxima vez que vayas a infligir Daño Arcano este turno, en su lugar infliges esa cifra mas X.", color: "orange" },
  { name: "Beat Chest", description: "Como un costo adicional para jugar esta carta, puedes descartar una carta con 6 o mas de poder.", color: "orange" },
  { name: "Channel", description: "Channel es una mecánica que usa cartas de Element para cumplir ciertas condiciones para mantener ciertas auras elementales poderosas en la arena.", color: "orange" },
  { name: "Ephemeral", description: "Si esta carta fuera a ser colocada en el cementerio desde cualquier lugar, en lugar de eso cesa de existir.", color: "orange" },
  { name: "Essence of ~X Element(s)~", description: "Puedes tener cartas de ~X Element(s)~ en tu baraja.", color: "orange" },
  { name: "Evo Upgrade", description: "Evo Upgrade - [...] por cada Evo que tengas equipada. Evo Upgrade - Donde X es el numero de Evos que tienes equipado.", color: "orange" },
  { name: "Heave X", description: "Al inicio de su fase final, si esta carta esta en su mano y tienes una espacio en el arsenal, puedes pagar X y poner esta carta boca arriba en la zona de arsenal. Si lo haces, crea X Seismic Surge tokens.", color: "orange" },
  { name: "Tower", description: "Tower - Si esta carta tiene 13 o mas poder, [...].", color: "orange" },
  { name: "Ambush", description: "Mientras esta carta este en tu Arsenal, puedes defender con ella.", color: "red" },
  { name: "Protect", description: "Puedes defender cualquier Héroe que sea atacado por un oponente con esta carta.", color: "red" },
  { name: "Universal", description: "Cuando esta carta se encuentra en cualquier zona, es de la misma clase que tu Héroe.", color: "red" },
];
---

<Layout>
<div class="mechanics-page">
    <div class="mechanics-header">
        <h1>Mecánicas de Juego</h1>
        <div class="stars">
            <span style="color: #91160d;">★</span>
            <span style="color: #765d2f;">★</span>
            <span style="color: #91160d;">★</span>
            <span style="color: #765d2f;">★</span>
            <span style="color: #91160d;">★</span>
        </div>
        <p class="subtitle">Referencia rápida de mecánicas</p>
    </div>
    <div class="mechanics-container">
        {mechanics.map((mechanic, index) => (
            <article class={`mechanic-ticket mechanic-${mechanic.color}`}>
                <div class="mechanic-ticket-name">
                    <span class="name">{mechanic.name}</span>
                </div>
                <div class="mechanic-ticket-content">
                    <p class="description">{mechanic.description}</p>
                </div>
            </article>
        ))}
    </div>
</div>
</Layout>
