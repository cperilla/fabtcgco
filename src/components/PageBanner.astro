---
const { image, alt } = Astro.props;
---

<figure class="page-banner">
  <img src={image} alt={alt} loading="lazy" />
</figure>

<style>
  .page-banner {
    width: min(100%, 960px);
    margin: 0 auto 2rem;
    overflow: hidden;
    border: 1px solid rgba(118, 93, 47, 0.34);
    border-radius: 0.75rem;
    background: var(--bg-dark-2, #141010);
  }

  .page-banner img {
    display: block;
    width: 100%;
    height: 240px;
    object-fit: cover;
  }

  @media (max-width: 640px) {
    .page-banner {
      margin-bottom: 1.5rem;
      border-radius: 0.5rem;
    }

    .page-banner img {
      height: 170px;
    }
  }
</style>
