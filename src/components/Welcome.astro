---
const title = "Bienvenido a FAB Colombia";

const sectionCards = [
  {
    href: "/empezar",
    title: "Empezar",
    description: "Guía rápida para jugar tu primera partida.",
    image: "/images/home/new-players.webp",
    alt: "Nuevos jugadores aprendiendo Flesh and Blood"
  },
  {
    href: "/mejorar",
    title: "Mejorar",
    description: "Herramientas y hábitos para jugar mejor.",
    image: "/images/home/improve-game.webp",
    alt: "Jugador practicando secuencias y mejorando su juego"
  },
  {
    href: "/calendar",
    title: "Calendario",
    description: "Eventos, torneos y sesiones de juego.",
    image: "/images/home/calendar-events.webp",
    alt: "Mesa de planificación de eventos de Flesh and Blood"
  },
  {
    href: "/rankings",
    title: "Rankings",
    description: "Resultados y posiciones locales.",
    image: "/images/home/local-rankings.webp",
    alt: "Trofeo y ambiente competitivo de rankings locales"
  },
  {
    href: "/competitivo",
    title: "Competitivo",
    description: "Rankings, reportes y estadísticas locales.",
    image: "/images/home/local-rankings.webp",
    alt: "Trofeo y ambiente competitivo de rankings locales"
  },
  {
    href: "/blog",
    title: "Blog",
    description: "Notas, noticias y reflexiones de comunidad.",
    image: "/images/home/blog-news.webp",
    alt: "Escritorio editorial con cartas y notas de estrategia"
  },
  {
    href: "/formatos",
    title: "Formatos",
    description: "Conoce las formas de jugar en la comunidad.",
    image: "/images/home/game-formats.webp",
    alt: "Formatos de juego de Flesh and Blood representados en una mesa"
  },
  {
    href: "/mechanics",
    title: "Mecánicas",
    description: "Guías para entender mejor el juego.",
    image: "/images/home/mechanics-guides.webp",
    alt: "Mesa de estudio con cartas y diagramas de mecánicas"
  }
];
---

<section class="py-8 px-4 max-w-5xl mx-auto backdrop-blur-md">

  <div class="welcome-hero">
    <img src="/images/FABLogo.png" alt="FAB Colombia" class="welcome-hero-logo" />
    <div class="welcome-hero-text">
      <h4>Comunidad de</h4>
      <h1 class="text-4xl font-bold">Flesh and Blood Colombia</h1>
    </div>
  </div>

  <!-- CTA para nuevos jugadores -->
  <div class="nuevo-cta">
    <span class="nuevo-label">¿Nuevo en FAB?</span>
    <a href="/empezar" class="nuevo-link">Empieza aqui →</a>
  </div>

  <div class="welcome-grid">
    <!-- Site Overview -->
    <div class="welcome-card">
      <img src="/images/home/organized-play.webp" alt="Evento organizado de Flesh and Blood en Colombia" class="welcome-image">
      <div class="welcome-content">
        <h2>Juego Organizado en Colombia</h2>
        <p>
          FAB Colombia es la comunidad de Flesh and Blood en Colombia. Organizamos torneos semanales,
          mantenemos rankings locales, y construimos una comunidad competitiva y respetuosa.
        </p>
        <ul class="welcome-features">
          <li><a href="/calendar">Calendario de eventos</a></li>
          <li><a href="/rankings">Rankings locales</a></li>
          <li><a href="/blog">Blog y noticias</a></li>
          <li><a href="/mechanics">Guias de mecanicas</a></li>
        </ul>
      </div>
    </div>

    <!-- Weekly Schedule -->
    <div class="welcome-card">
      <img src="/images/home/weekly-schedule.webp" alt="Horario semanal de eventos de Flesh and Blood" class="welcome-image">
      <div class="welcome-content">
        <h2>Horario Semanal</h2>

        <h3 class="location-header">Chaos Store - Cali</h3>
        <div class="schedule-list">
          <div class="schedule-item">
            <span class="schedule-day">Martes</span>
            <span class="schedule-event">Free Play - 5 PM</span>
          </div>
          <div class="schedule-item">
            <span class="schedule-day">Jueves</span>
            <span class="schedule-event">Silver Age / CC - 5 PM</span>
          </div>
          <div class="schedule-item">
            <span class="schedule-day">Sabados</span>
            <span class="schedule-event">CC / Silver Age - 3 PM</span>
          </div>
          <div class="schedule-item schedule-special">
            <span class="schedule-day">Ultimo Sabado</span>
            <span class="schedule-event">Living Legend - 3 PM</span>
          </div>
        </div>

        <h3 class="location-header">Palmira</h3>
        <div class="schedule-list">
          <div class="schedule-item">
            <span class="schedule-day">Sabados</span>
            <span class="schedule-event">Silver Age - 3 PM</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Goldfish Tool -->
    <div class="welcome-card welcome-card-wide">
      <img src="https://static.fabtcgcolombia.club/public/r2/FABCO_IA_INSPIRATIONAL_06.png" alt="Goldfish Practice Tool" class="welcome-image">
      <div class="welcome-content">
        <h2>Herramienta Goldfish</h2>
        <p>
          <strong>Goldfish</strong> es la practica de jugar tu mazo en solitario, sin oponente.
          Te permite aprender las secuencias de tu mazo, optimizar tus lineas de juego, y calcular
          tu danio promedio por turno.
        </p>
        <p>
          Hemos desarrollado una herramienta especial para practicar goldfish con tu mazo de FAB.
        </p>
        <a href="https://goldfish.fabtcgcolombia.club" target="_blank" rel="noopener noreferrer" class="goldfish-link">
          Ir a Goldfish Tool
        </a>
      </div>
    </div>
  </div>

  <section class="section-directory" aria-label="Secciones principales">
    <div class="section-card-grid">
      {sectionCards.map((card) => (
        <a href={card.href} class="section-card">
          <img src={card.image} alt={card.alt} />
          <div class="section-card-content">
            <h3>{card.title}</h3>
            <p>{card.description}</p>
          </div>
        </a>
      ))}
    </div>
  </section>
</section>

<style>
  .welcome-grid {
    display: grid;
    gap: 2rem;
    margin-top: 2rem;
    text-align: left;
  }

  @media (min-width: 768px) {
    .welcome-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .welcome-card-wide {
      grid-column: span 2;
    }
  }

  .welcome-card {
    background: var(--bg-dark-2, rgba(0, 0, 0, 0.3));
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .welcome-card-wide {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .welcome-card-wide {
      grid-template-columns: 300px 1fr;
    }
  }

  .welcome-image {
    width: 100%;
    height: 220px;
    object-fit: cover;
  }

  @media (min-width: 768px) {
    .welcome-card-wide .welcome-image {
      height: 100%;
    }
  }

  @media (max-width: 640px) {
    .welcome-image {
      height: 180px;
    }
  }

  .welcome-content {
    padding: 1.5rem;
  }

  .welcome-content h2 {
    color: var(--primary-color, #c41e3a);
    margin: 0 0 1rem 0;
    font-size: 1.25rem;
  }

  .welcome-content p {
    color: var(--text-color, #e0e0e0);
    line-height: 1.6;
    margin: 0 0 1rem 0;
  }

  .welcome-features {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .welcome-features li {
    margin-bottom: 0.5rem;
  }

  .welcome-features a {
    color: var(--accent-light, #64b5f6);
    text-decoration: none;
  }

  .welcome-features a:hover {
    text-decoration: underline;
  }

  .location-header {
    color: var(--accent-light, #64b5f6);
    font-size: 1rem;
    margin: 0 0 0.5rem 0;
    padding-bottom: 0.25rem;
    border-bottom: 2px solid var(--accent-light, #64b5f6);
  }

  .location-header:not(:first-of-type) {
    margin-top: 1rem;
  }

  .schedule-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .schedule-item {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .schedule-day {
    font-weight: bold;
    color: var(--primary-color, #c41e3a);
  }

  .schedule-event {
    color: var(--text-color, #e0e0e0);
  }

  .schedule-special {
    background: rgba(118, 93, 47, 0.2);
    padding: 0.5rem;
    border-radius: 0.5rem;
    border: none;
  }

  .schedule-note {
    font-size: 0.875rem;
    color: var(--muted-color, #888);
    font-style: italic;
  }

  .goldfish-link {
    display: inline-block;
    background: linear-gradient(135deg, #4a7c4e 0%, #2d5a30 100%);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: bold;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .goldfish-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(74, 124, 78, 0.4);
  }

  .section-directory {
    margin-top: 2rem;
  }

  .section-directory h2 {
    color: var(--neutral-color, #f5ebe9);
    font-size: 1.4rem;
    margin: 0 0 1rem;
  }

  .section-card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .section-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .section-card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .section-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-height: 100%;
    background: var(--bg-dark-2, rgba(0, 0, 0, 0.3));
    border: 1px solid rgba(118, 93, 47, 0.28);
    border-radius: 0.75rem;
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .section-card:hover {
    border-color: rgba(221, 173, 46, 0.65);
    transform: translateY(-2px);
  }

  .section-card img {
    width: 100%;
    height: 160px;
    object-fit: cover;
  }

  .section-card-content {
    padding: 1rem;
  }

  .section-card h3 {
    margin: 0 0 0.4rem;
    color: var(--accent-light, #f6ce59);
    font-size: 1rem;
  }

  .section-card p {
    margin: 0;
    color: var(--text-secondary, #c8b8b0);
    font-size: 0.875rem;
    line-height: 1.4;
  }

  /* CTA para nuevos jugadores */
  .nuevo-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, rgba(196, 30, 58, 0.15) 0%, rgba(196, 30, 58, 0.05) 100%);
    border: 1px solid rgba(196, 30, 58, 0.3);
    border-radius: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .nuevo-label {
    color: var(--text-color, #e0e0e0);
    font-size: 1rem;
  }

  .nuevo-link {
    display: inline-block;
    background: linear-gradient(135deg, #c41e3a 0%, #91160d 100%);
    color: white;
    padding: 0.5rem 1.25rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .nuevo-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(196, 30, 58, 0.4);
  }

  @media (max-width: 640px) {
    .nuevo-cta {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
